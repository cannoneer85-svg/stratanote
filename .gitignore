# Exclude all top-level note folders and untracked files, keeping only application code
/*
!/_app/
!/_sync_mcp/
!/.gitignore
!/start.bat
!/README.md
!/README.ru.md
!/.agents/
!/CHANGELOG.md
!/.env.template
!/docs/
!/LICENSE
!/.github/
!/.mintlify/


# Gemini system generated tasks and logs
.system_generated/
brain/
scratch/
task.md
walkthrough.md
implementation_plan.md

# Environment variables
.env
_app/.env
_app/server/.env
_sync_mcp/config.json

